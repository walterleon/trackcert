generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "rhel-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Company {
  id              String    @id @default(uuid())
  name            String
  email           String    @unique
  passwordHash    String?
  googleId        String?   @unique
  role            String    @default("COMPANY") // COMPANY, SUPER_ADMIN
  credits         Int       @default(30)  // monthly credits remaining this cycle
  bonusCredits    Int       @default(0)   // purchased credits (never expire)
  planName        String    @default("free") // free, starter, growth, pro
  nextRenewalDate DateTime? // when monthly credits renew next
  campaigns       Campaign[]
  photos          Photo[]
  subscriptions      Subscription[]
  creditTransactions CreditTransaction[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Subscription {
  id            String    @id @default(uuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  planName      String
  status        String    @default("active") // active, cancelled, expired
  startDate     DateTime  @default(now())
  endDate       DateTime?
  mercadopagoId String?
  createdAt     DateTime  @default(now())
}

model Campaign {
  id             String     @id @default(uuid())
  companyId      String
  company        Company    @relation(fields: [companyId], references: [id])
  title          String
  description    String?    @db.Text
  campaignCode   String     @unique // short code e.g. "CAMP-ABCD12"
  validationCode String
  isActive       Boolean    @default(true)
  shareToken     String?    @unique
  sharePin       String?
  startDate      DateTime?
  endDate        DateTime?
  drivers        Driver[]
  locations      Location[]
  photos         Photo[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Driver {
  id         String     @id @default(uuid())
  alias      String
  campaignId String
  campaign   Campaign   @relation(fields: [campaignId], references: [id])
  locations  Location[]
  photos     Photo[]
  deviceId   String?
  deviceInfo String?  @db.Text
  isActive   Boolean    @default(true)
  lastSeenAt DateTime?
  joinedAt   DateTime   @default(now())

  @@unique([deviceId, campaignId])
}

model Location {
  id            Int      @id @default(autoincrement())
  driverId      String
  driver        Driver   @relation(fields: [driverId], references: [id])
  campaignId    String
  campaign      Campaign @relation(fields: [campaignId], references: [id])
  latitude      Float
  longitude     Float
  accuracy      Float?
  batteryLevel  Float?
  timestamp     DateTime
  isOfflineSync Boolean  @default(false)

  @@index([campaignId])
  @@index([driverId])
  @@index([timestamp])
}

model Photo {
  id         String   @id @default(uuid())
  driverId   String
  driver     Driver   @relation(fields: [driverId], references: [id])
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])
  latitude   Float
  longitude  Float
  accuracy   Float?
  filePath   String
  fileUrl    String
  takenAt    DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([campaignId])
  @@index([driverId])
}

model CreditTransaction {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  amount    Int
  reason    String  @db.Text
  createdAt DateTime @default(now())
}
